# Copy this to .env.local and fill in real values.
# .env.local is gitignored.

# Core
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...

# Auth — required
SESSION_SECRET=                   # openssl rand -hex 32
ALLOWED_EMAILS=you@example.com    # comma-separated allowlist
APP_URL=http://localhost:3000     # or your public URL

# Email — optional
# If RESEND_API_KEY is blank, magic links are printed to the server log
# (useful for local dev). Set this + a verified RESEND_FROM for production.
RESEND_API_KEY=
RESEND_FROM=MedQuiz <onboarding@resend.dev>
